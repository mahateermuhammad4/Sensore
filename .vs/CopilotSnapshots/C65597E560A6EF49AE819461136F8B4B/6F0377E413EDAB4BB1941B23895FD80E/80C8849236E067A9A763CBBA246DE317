<Application x:Class="Sensore.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:vm="clr-namespace:Sensore.ViewModels">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <Border Padding="24" MaxWidth="420" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="SENSORE" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Pressure Ulcer Prevention System" Margin="0,0,0,20" Foreground="#666" />

                    <TextBlock Text="Email" />
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" MinHeight="32" />

                    <TextBlock Text="Password" />
                    <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" MinHeight="32" />

                    <Button Content="Log In" Command="{Binding LoginCommand}" MinHeight="34" />
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828" Margin="0,12,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PatientDashboardViewModel}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Patient Dashboard" FontSize="26" FontWeight="SemiBold" />

                <Border Grid.Row="1" Background="#FFC107" Padding="10" Margin="0,12,0,0"
                        Visibility="{Binding IsAlertVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <DockPanel>
                        <TextBlock Text="{Binding AlertMessage}" FontWeight="SemiBold" />
                        <Button Content="Dismiss" Command="{Binding AcknowledgeAlertCommand}" Width="90" Margin="12,0,0,0" HorizontalAlignment="Right" />
                    </DockPanel>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="Import CSV" Width="120" Command="{Binding ImportCsvCommand}" />
                    <TextBlock Margin="16,8,0,0" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,16,0,0">
                    <TextBlock Text="Current Metrics" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding Ppi, StringFormat=PPI: {0:F0}}" />
                    <TextBlock Text="{Binding ContactArea, StringFormat=Contact Area: {0:F2}%}" />
                    <Button Content="Log Out" Width="120" Command="{Binding LogoutCommand}" Margin="0,16,0,0" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ClinicianDashboardViewModel}">
            <StackPanel Margin="24">
                <TextBlock Text="Clinician Dashboard" FontSize="26" FontWeight="SemiBold" />
                <TextBlock Text="Foundation setup complete. Next step is patient list, flagged events, and report generation." Margin="0,12,0,16" />
                <Button Content="Log Out" Width="120" Command="{Binding LogoutCommand}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:AdminDashboardViewModel}">
            <StackPanel Margin="24">
                <TextBlock Text="Admin Dashboard" FontSize="26" FontWeight="SemiBold" />
                <TextBlock Text="Foundation setup complete. Next step is account management and clinician-patient assignment." Margin="0,12,0,16" />
                <Button Content="Log Out" Width="120" Command="{Binding LogoutCommand}" />
            </StackPanel>
        </DataTemplate>
    </Application.Resources>
</Application>
