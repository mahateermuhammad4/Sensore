using Microsoft.EntityFrameworkCore;
using Sensore.Data;
using Sensore.Models;

namespace Sensore.Services;

public class PatientFrameQueryService
{
    private readonly AppDbContext _dbContext;

    public PatientFrameQueryService(AppDbContext dbContext)
    {
        _dbContext = dbContext;
    }

    public Task<SensorFrame?> GetLatestFrameAsync(int userId)
    {
        return _dbContext.SensorFrames
            .AsNoTracking()
            .Where(f => f.UserId == userId)
            .OrderByDescending(f => f.Timestamp)
            .FirstOrDefaultAsync();
    }

    public Task<List<SensorFrame>> GetFramesForWindowAsync(int userId, TimeSpan window)
    {
        var threshold = DateTime.UtcNow.Subtract(window);

        return _dbContext.SensorFrames
            .AsNoTracking()
            .Where(f => f.UserId == userId && f.Timestamp >= threshold)
            .OrderBy(f => f.Timestamp)
            .ToListAsync();
    }

    public Task<List<Comment>> GetCommentsForFrameAsync(int frameId)
    {
        return _dbContext.Comments
            .AsNoTracking()
            .Include(c => c.Author)
            .Where(c => c.FrameId == frameId)
            .OrderBy(c => c.CreatedAt)
            .ToListAsync();
    }

    public async Task AddCommentAsync(int frameId, int authorId, string content, int? parentCommentId = null)
    {
        var comment = new Comment
        {
            FrameId = frameId,
            AuthorId = authorId,
            ParentCommentId = parentCommentId,
            Content = content,
            CreatedAt = DateTime.UtcNow
        };

        _dbContext.Comments.Add(comment);
        await _dbContext.SaveChangesAsync();
    }
}
